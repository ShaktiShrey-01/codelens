# Server
PORT=5000
NODE_ENV=development

# Database
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/codelens

# Auth secrets
ACCESS_TOKEN_SECRET=replace-with-strong-random-secret
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_SECRET=replace-with-strong-random-secret
REFRESH_TOKEN_EXPIRY=10d

# AI
GEMINI_API_KEY=your-gemini-api-key

# CORS
# Comma-separated list for multiple origins
CORS_ORIGINS=http://localhost:5173
